# Copy to .env for local development. The gateway defaults `environment` to
# "production", which FAIL-CLOSES the boot if jwt_secret is still the dev
# default — so local dev MUST declare a non-prod environment explicitly.

# Deployment environment. Non-prod values: dev | development | test | local.
# Anything else (or absence) is treated as production and arms the fail-closed
# auth guards (real jwt_secret required; self-registration closed).
ENVIRONMENT=dev

# Auth. In production this MUST be a real secret (e.g. via SOPS); the dev
# default is rejected at boot when ENVIRONMENT is production-like.
JWT_SECRET=dev-insecure-change-me

# Self-service registration. Omit to use the environment default (open in dev,
# closed in prod). Set explicitly to override either way.
# OPEN_REGISTRATION=true

# --- aiko bus ---
AIKO_MQTT_HOST=localhost
AIKO_MQTT_PORT=1883
AIKO_NAMESPACE=aiko

# --- database ---
DB_URL=postgresql+asyncpg://aiko:dev@localhost:5433/aiko_chat
