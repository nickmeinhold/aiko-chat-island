# ============================================================================
# LOCAL DEVELOPMENT ONLY. Never deploy this file (or a .env derived from it) to
# production. Production supplies config via real secrets management (SOPS) and
# must NOT declare a non-prod ENVIRONMENT. Copy to .env for local work.
# ============================================================================
#
# The gateway defaults `environment` to "production", which FAIL-CLOSES the boot
# unless a strong (>= 32 char, non-default) jwt_secret is supplied. Declaring a
# non-prod ENVIRONMENT below is what relaxes that for local dev.

# Deployment environment. Non-prod values: dev | development | test | local.
# Absence — or any other value — is treated as production and arms the
# fail-closed auth guards.
ENVIRONMENT=dev

# Auth. LEFT UNSET ON PURPOSE: in dev (above) the code falls back to its
# built-in dev secret, so local dev needs nothing here. In production this MUST
# be a real >= 32-char secret from SOPS — never copied from this file.
# JWT_SECRET=

# Self-service registration. Omit to use the environment default (open in dev,
# closed in prod). In production an explicit `true` is REJECTED at boot until I2
# membership lands (#36).
# OPEN_REGISTRATION=true

# --- aiko bus ---
AIKO_MQTT_HOST=localhost
AIKO_MQTT_PORT=1883
AIKO_NAMESPACE=aiko

# --- database ---
# Dev defaults to file-backed SQLite — the SAME engine prod runs — so local work
# exercises SQLite's real behavior (single-writer locking, type affinity, CHECK
# quirks, FK-off + app-level cascades) instead of being blind to it on Postgres.
# Omit to use the built-in default (./aiko_dev.db). Prod sets the absolute-path
# form: DB_URL=sqlite+aiosqlite:////data/aiko.db.
# DB_URL=sqlite+aiosqlite:///./aiko_dev.db
